{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "email:dev": "email dev --dir emails --port 3000",
    "email:export": "email export --outDir emails/html",
    "preview": "vite preview",
    "generate:api": "node scripts/fetch-openapi.mjs && openapi-ts",
    "prepare": "node -e \"try{const cp=require('child_process');cp.execSync('git rev-parse --is-inside-work-tree',{stdio:'ignore'});cp.execSync('git config core.hooksPath scripts/git-hooks',{stdio:'ignore'})}catch(e){}\""
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,json,css,md}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "next@<16.2.6": ">=16.2.6",
      "postcss@<8.5.10": ">=8.5.10",
      "hono@<4.12.25": ">=4.12.25",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0"
    }
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "@radix-ui/react-select": "^2.2.6",
    "@react-email/tailwind": "^2.0.7",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@xstate/react": "^6.1.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "date-fns": "^4.3.0",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-leaflet": "^5.0.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xstate": "^5.31.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "0.97.2",
    "@react-email/components": "^1.0.12",
    "@react-email/preview-server": "^5.2.10",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "react-email": "^5.2.11",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-svgr": "^4.5.0"
  }
}
